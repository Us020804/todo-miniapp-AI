<view class="container"><view class="title">我的待办清单</view><view class="input-area"><input class="task-input" placeholder="请输入待办事项" value="{{a}}" bindinput="{{b}}"/><button class="add-btn" bindtap="{{c}}">添加</button></view><view class="stats-area"><text>总数：{{d}}</text><text>已完成：{{e}}</text><text>未完成：{{f}}</text></view><view class="filter-area"><button class="{{['filter-btn', g && 'filterActive']}}" size="mini" bindtap="{{h}}"> 全部 </button><button class="{{['filter-btn', i && 'filterActive']}}" size="mini" bindtap="{{j}}"> 未完成 </button><button class="{{['filter-btn', k && 'filterActive']}}" size="mini" bindtap="{{l}}"> 已完成 </button></view><view class="list-area"><view wx:for="{{m}}" wx:for-item="item" wx:key="d" class="task-item"><view class="{{['task-text', item.b && 'completed']}}">{{item.a}}</view><view class="btn-group"><button class="edit-btn" size="mini" bindtap="{{item.c}}"> 修改 </button></view></view><view wx:if="{{n}}" class="empty-tip"> 当前筛选下没有任务 </view></view><view wx:if="{{o}}" class="popup-mask" bindtap="{{w}}"><view class="popup-content" catchtap="{{v}}"><view class="popup-title">任务操作</view><button class="popup-btn" bindtap="{{p}}">设为已完成</button><button class="popup-btn" bindtap="{{q}}">设为未完成</button><button class="popup-btn" bindtap="{{r}}">编辑任务内容</button><button class="popup-btn delete-popup-btn" bindtap="{{s}}"> 删除 </button><button class="popup-cancel-btn" bindtap="{{t}}"> 取消 </button></view></view><view wx:if="{{x}}" class="popup-mask" bindtap="{{D}}"><view class="popup-content" catchtap="{{C}}"><view class="popup-title">编辑任务</view><input class="edit-input" placeholder="请输入新的任务内容" value="{{y}}" bindinput="{{z}}"/><button class="popup-btn confirm-btn" bindtap="{{A}}">确定</button><button class="popup-cancel-btn" bindtap="{{B}}">取消</button></view></view></view>